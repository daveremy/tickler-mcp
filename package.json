{
  "name": "tickler-mcp",
  "version": "1.0.1",
  "description": "Persistent tickler/reminder MCP server for Claude Code and any MCP client",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tickler",
    "reminder",
    "cli",
    "agent",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daveremy/tickler-mcp.git"
  },
  "bin": {
    "tickler": "./dist/cli.js",
    "tickler-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist/",
    ".claude-plugin/",
    "skills/"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js dist/mcp.js",
    "prepack": "npm run build",
    "dev": "tsx src/mcp.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "release": "./scripts/release.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
